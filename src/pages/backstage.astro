---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoGallery from '../components/PhotoGallery.astro';

// Récupérer le contenu backstage
const backstage = await getEntry('backstage', 'index');
---

<BaseLayout
  title="Backstage - Saskia Maitrepierre"
  description="Photos des coulisses de tournage et événements"
>
  <!-- Hero Section -->
  <section class="py-20 bg-[#E8E4DF]">
    <div class="container-custom">
      <h1 class="hero-title mb-6">BACKSTAGE</h1>
      <p class="text-lg text-gray-700 max-w-2xl">
        Coulisses de tournage, maquillage, préparation et moments en arrière-plan.
      </p>
    </div>
  </section>

  <!-- Galerie backstage -->
  <section class="py-16 bg-white">
    <div class="container-custom">
      <PhotoGallery
        images={backstage.data.images}
        columns={4}
        gap={6}
      />
    </div>
  </section>
</BaseLayout>
