---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="À propos - Saskia Maitrepierre"
  description="Réalisatrice, photographe et monteuse basée à Paris"
>
  <!-- Hero Section -->
  <section class="py-20 bg-[#E8E4DF]">
    <div class="container-custom max-w-4xl">
      <h1 class="hero-title mb-12">À PROPOS</h1>

      <!-- Bio -->
      <div class="space-y-8 text-lg leading-relaxed text-gray-800">
        <p>
          Basée à Paris, <strong>Saskia Maitrepierre</strong> est réalisatrice, photographe et monteuse.
        </p>

        <p>
          Très inspirée par la <strong>Nouvelle Vague</strong>, son approche artistique est marquée par
          la mise en valeur des portraits et des histoires personnelles.
        </p>

        <p>
          Elle a collaboré avec le directeur de la photographie <strong>Michel Abramowicz</strong> pour
          créer trois courts-métrages.
        </p>

        <p>
          Son travail se concentre principalement sur les <strong>portraits de femmes et d'enfants</strong>.
        </p>
      </div>

      <!-- Contact -->
      <div class="mt-16 pt-16 border-t border-gray-300">
        <h2 class="text-3xl font-bold uppercase mb-8" style="font-family: 'Pragmatica Extended', sans-serif; letter-spacing: -0.05em;">
          Contact
        </h2>

        <div class="grid md:grid-cols-2 gap-12">
          <!-- Formulaire de contact -->
          <div>
            <form
              name="contact"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              class="space-y-6"
            >
              <input type="hidden" name="form-name" value="contact" />
              <p class="hidden">
                <label>
                  Don't fill this out if you're human: <input name="bot-field" />
                </label>
              </p>

              <div>
                <label for="prenom" class="block text-sm font-medium mb-2">
                  Prénom <span class="text-red-600">*</span>
                </label>
                <input
                  type="text"
                  id="prenom"
                  name="prenom"
                  required
                  class="w-full px-4 py-3 border border-gray-300 focus:border-black focus:outline-none transition-colors"
                />
              </div>

              <div>
                <label for="nom" class="block text-sm font-medium mb-2">
                  Nom de famille <span class="text-red-600">*</span>
                </label>
                <input
                  type="text"
                  id="nom"
                  name="nom"
                  required
                  class="w-full px-4 py-3 border border-gray-300 focus:border-black focus:outline-none transition-colors"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium mb-2">
                  E-mail <span class="text-red-600">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 border border-gray-300 focus:border-black focus:outline-none transition-colors"
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-medium mb-2">
                  Message <span class="text-red-600">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="6"
                  class="w-full px-4 py-3 border border-gray-300 focus:border-black focus:outline-none transition-colors resize-vertical"
                ></textarea>
              </div>

              <button
                type="submit"
                class="px-8 py-3 bg-black text-white uppercase text-sm tracking-wide hover:opacity-80 transition-opacity"
              >
                Envoyer
              </button>
            </form>
          </div>

          <!-- Informations de contact -->
          <div class="space-y-6">
            <div>
              <h3 class="text-sm font-medium uppercase tracking-wide mb-3">Email</h3>
              <p>
                <a
                  href="mailto:saskiamaitrepierre@gmail.com"
                  class="text-lg hover:opacity-70 transition-opacity underline"
                  style="font-family: 'Courier Std', monospace;"
                >
                  saskiamaitrepierre@gmail.com
                </a>
              </p>
            </div>

            <div>
              <h3 class="text-sm font-medium uppercase tracking-wide mb-3">Réseaux sociaux</h3>
              <div class="flex flex-col gap-3">
                <a
                  href="https://instagram.com/saskiamaitrepierre"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:opacity-70 transition-opacity underline"
                  style="font-family: 'Courier Std', monospace;"
                >
                  Instagram
                </a>
                <a
                  href="https://vimeo.com/saskiamaitrepierre"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:opacity-70 transition-opacity underline"
                  style="font-family: 'Courier Std', monospace;"
                >
                  Vimeo
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
