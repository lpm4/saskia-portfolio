---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';

export async function getStaticPaths() {
  const photos = await getCollection('photos');
  return photos.map((gallery) => ({
    params: { slug: gallery.slug },
    props: { gallery },
  }));
}

const { gallery } = Astro.props;
const { Content } = await gallery.render();
---

<BaseLayout
  title={`${gallery.data.subject} - Photos - Saskia Maitrepierre`}
  description={`Galerie photo de ${gallery.data.subject}`}
>
  <!-- Gallery Section -->
  <section class="py-20 bg-[#E8E4DF]">
    <div class="container-custom">
      <!-- Breadcrumb -->
      <nav class="mb-8">
        <a href="/photos" class="text-sm uppercase tracking-wide hover:opacity-70 transition-opacity">
          ← Photos
        </a>
      </nav>

      <!-- Titre -->
      <h1 class="text-5xl font-bold uppercase tracking-wide mb-12" style="font-family: 'Pragmatica Extended', sans-serif; letter-spacing: -0.05em;">
        {gallery.data.subject}
      </h1>

      <!-- Galerie de photos -->
      <PhotoGallery
        images={gallery.data.images}
        columns={3}
        gap={8}
      />

      <!-- Contenu markdown (si présent) -->
      {Content && (
        <div class="prose prose-lg max-w-3xl mt-12">
          <Content />
        </div>
      )}
    </div>
  </section>

  <!-- Navigation -->
  <section class="py-12 bg-white border-t border-gray-200">
    <div class="container-custom">
      <a
        href="/photos"
        class="inline-block px-6 py-3 bg-black text-white uppercase text-sm tracking-wide hover:opacity-80 transition-opacity"
      >
        Voir toutes les galeries
      </a>
    </div>
  </section>
</BaseLayout>
