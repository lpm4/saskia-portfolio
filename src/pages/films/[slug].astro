---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoPlayer from '../../components/VideoPlayer.astro';

export async function getStaticPaths() {
  const films = await getCollection('films');
  return films.map((film) => ({
    params: { slug: film.slug },
    props: { film },
  }));
}

const { film } = Astro.props;
const { Content } = await film.render();

// Formater la catégorie
const categoryLabel = film.data.category.charAt(0).toUpperCase() + film.data.category.slice(1);
---

<BaseLayout
  title={`${film.data.title} - Saskia Maitrepierre`}
  description={film.data.description}
>
  <!-- Film Section -->
  <section class="py-20 bg-[#E8E4DF]">
    <div class="container-custom max-w-5xl">
      <!-- Breadcrumb -->
      <nav class="mb-8">
        <a href="/films" class="text-sm uppercase tracking-wide hover:opacity-70 transition-opacity">
          ← Films
        </a>
      </nav>

      <!-- Titre et catégorie -->
      <div class="mb-8">
        <p class="text-xs uppercase tracking-widest text-gray-600 mb-2">
          {categoryLabel}
          {film.data.year && ` • ${film.data.year}`}
        </p>
        <h1 class="text-5xl font-bold uppercase tracking-wide mb-4" style="font-family: 'Pragmatica Extended', sans-serif; letter-spacing: -0.05em;">
          {film.data.title}
        </h1>
        <p class="text-lg text-gray-700 leading-relaxed max-w-3xl">
          {film.data.description}
        </p>
      </div>

      <!-- Video Player -->
      <div class="mb-12">
        <VideoPlayer
          videoId={film.data.videoId}
          platform={film.data.videoPlatform}
          thumbnailUrl={film.data.thumbnailUrl}
          title={film.data.title}
          aspectRatio="16/9"
        />
      </div>

      <!-- Contenu markdown (si présent) -->
      {Content && (
        <div class="prose prose-lg max-w-3xl">
          <Content />
        </div>
      )}
    </div>
  </section>

  <!-- Navigation vers autres films (optionnel) -->
  <section class="py-12 bg-white border-t border-gray-200">
    <div class="container-custom">
      <h2 class="text-2xl font-bold uppercase mb-8" style="font-family: 'Pragmatica Extended', sans-serif;">
        Autres films
      </h2>
      <a
        href="/films"
        class="inline-block px-6 py-3 bg-black text-white uppercase text-sm tracking-wide hover:opacity-80 transition-opacity"
      >
        Voir tous les films
      </a>
    </div>
  </section>
</BaseLayout>
