---
interface Props {
  videoId: string; // ID Vimeo/YouTube ou URL fichier
  platform: 'vimeo' | 'youtube' | 'file';
  thumbnailUrl?: string | undefined; // Image de couverture (optionnelle)
  title: string;
  aspectRatio?: string;
  class?: string;
}

const {
  videoId,
  platform,
  thumbnailUrl,
  title,
  aspectRatio = '16/9',
  class: className = '',
} = Astro.props;

// Générer les URLs d'embed selon la plateforme
const getEmbedUrl = () => {
  switch (platform) {
    case 'vimeo':
      return `https://player.vimeo.com/video/${videoId}?title=0&byline=0&portrait=0`;
    case 'youtube':
      return `https://www.youtube.com/embed/${videoId}`;
    case 'file':
      return videoId; // URL directe du fichier
    default:
      return '';
  }
};

const embedUrl = getEmbedUrl();
---

<div
  class:list={[
    'relative overflow-hidden bg-gray-900 w-full',
    className
  ]}
  style={`aspect-ratio: ${aspectRatio};`}
>
  {platform === 'file' ? (
    <video
      src={embedUrl}
      controls
      class="w-full h-full"
      poster={thumbnailUrl}
    >
      Votre navigateur ne supporte pas la lecture de vidéos.
    </video>
  ) : (
    <iframe
      src={embedUrl}
      title={title}
      frameborder="0"
      allow="autoplay; fullscreen; picture-in-picture; clipboard-write"
      allowfullscreen
      class="w-full h-full"
      loading="lazy"
    ></iframe>
  )}
</div>
