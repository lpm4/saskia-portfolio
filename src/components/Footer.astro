---
const socialLinks = [
  {
    label: 'INSTAGRAM',
    url: 'https://instagram.com/saskiamaitrepierre',
  },
  {
    label: 'VIMÉO',
    url: 'https://vimeo.com/saskiamaitrepierre',
  },
];
---

<footer class="bg-black text-white">
  <div class="px-6 md:px-8 py-16 md:py-20">
    <div class="flex flex-col md:flex-row md:justify-between gap-12 max-w-full">
      <!-- Réseaux Sociaux -->
      <div>
        <h3 class="footer-title mb-6">
          RÉSEAUX SOCIAUX
        </h3>
        <ul class="flex flex-col gap-4">
          {socialLinks.map(({ label, url }) => (
            <li>
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm md:text-base underline hover:opacity-70 transition-base inline-block text-white"
                style="font-family: 'Courier Std', 'Courier New', monospace;"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:text-right">
        <h3 class="footer-title mb-6">
          CONTACT
        </h3>
        <a
          href="mailto:saskiamaitrepierre@gmail.com"
          class="text-sm md:text-base hover:opacity-70 transition-base text-white block"
          style="font-family: 'Courier Std', 'Courier New', monospace;"
        >
          saskiamaitrepierre@gmail.com
        </a>
      </div>
    </div>
  </div>
</footer>
