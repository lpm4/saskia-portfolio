---
import CloudinaryImage from './CloudinaryImage.astro';

interface Props {
  images: string[]; // Array d'URLs Cloudinary
  columns?: number; // Nombre de colonnes (2, 3, 4)
  gap?: number; // Espacement en pixels
}

const {
  images,
  columns = 3,
  gap = 8,
} = Astro.props;

// Classes CSS pour les colonnes
const gridColsClass = {
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-3',
  4: 'md:grid-cols-4',
}[columns] || 'md:grid-cols-3';

const gapClass = `gap-${gap}`;
---

<div class:list={[
  'grid grid-cols-1',
  gridColsClass,
  gapClass,
]}>
  {images.map((imageUrl, index) => (
    <div
      class="aspect-[3/4] overflow-hidden bg-gray-200 cursor-pointer hover:opacity-90 transition-opacity"
      data-gallery-item
      data-index={index}
    >
      <CloudinaryImage
        src={imageUrl}
        alt={`Photo ${index + 1}`}
        widths={[400, 800, 1200]}
        sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
        aspectRatio="3/4"
      />
    </div>
  ))}
</div>

<!-- Lightbox modale (optionnelle - à implémenter plus tard) -->
<div
  id="lightbox"
  class="fixed inset-0 z-[200] bg-black/95 hidden items-center justify-center"
  data-lightbox
>
  <button
    class="absolute top-6 right-6 text-white text-4xl hover:opacity-70"
    data-lightbox-close
    aria-label="Fermer"
  >
    ×
  </button>

  <button
    class="absolute left-6 top-1/2 -translate-y-1/2 text-white text-4xl hover:opacity-70"
    data-lightbox-prev
    aria-label="Précédent"
  >
    ‹
  </button>

  <button
    class="absolute right-6 top-1/2 -translate-y-1/2 text-white text-4xl hover:opacity-70"
    data-lightbox-next
    aria-label="Suivant"
  >
    ›
  </button>

  <img
    id="lightbox-image"
    src=""
    alt=""
    class="max-w-[90vw] max-h-[90vh] object-contain"
  />
</div>

<script define:vars={{ images }}>
  document.addEventListener('DOMContentLoaded', () => {
    const lightbox = document.querySelector('[data-lightbox]');
    const lightboxImage = document.getElementById('lightbox-image');
    const closeBtn = document.querySelector('[data-lightbox-close]');
    const prevBtn = document.querySelector('[data-lightbox-prev]');
    const nextBtn = document.querySelector('[data-lightbox-next]');
    const galleryItems = document.querySelectorAll('[data-gallery-item]');

    let currentIndex = 0;

    const showImage = (index) => {
      currentIndex = index;
      if (lightboxImage) {
        lightboxImage.src = images[index];
        lightboxImage.alt = `Photo ${index + 1}`;
      }
      lightbox?.classList.remove('hidden');
      lightbox?.classList.add('flex');
    };

    const hideImage = () => {
      lightbox?.classList.add('hidden');
      lightbox?.classList.remove('flex');
    };

    // Ouvrir lightbox au clic sur une image
    galleryItems.forEach((item, index) => {
      item.addEventListener('click', () => showImage(index));
    });

    // Fermer lightbox
    closeBtn?.addEventListener('click', hideImage);
    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) hideImage();
    });

    // Navigation
    prevBtn?.addEventListener('click', () => {
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      showImage(currentIndex);
    });

    nextBtn?.addEventListener('click', () => {
      currentIndex = (currentIndex + 1) % images.length;
      showImage(currentIndex);
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!lightbox?.classList.contains('flex')) return;

      if (e.key === 'Escape') hideImage();
      if (e.key === 'ArrowLeft') prevBtn?.click();
      if (e.key === 'ArrowRight') nextBtn?.click();
    });
  });
</script>
